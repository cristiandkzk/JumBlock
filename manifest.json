{
  "manifest_version": 3,
  "name": "JumpBlock",
  "version": "0.1.0",
  "description": "Detecta publicidad en YouTube/Twitch y la saltea automaticamente (no bloquea la request). Banners en otras webs son opcionales.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.twitch.tv/*"],
  "optional_host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/twitch.js"],
      "run_at": "document_idle"
    }
  ]
}
